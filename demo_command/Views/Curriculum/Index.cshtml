@{
    Layout = null; // Remove qualquer interferência do layout padrão do ASP.NET
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carreiras na Microsoft - Enviar Currículo</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        body {
            /* Pilha de fontes exata usada pela Microsoft */
            font-family: "Segoe UI", SegoeUI, "Helvetica Neue", Helvetica, Arial, sans-serif;
            background-color: #ffffff; /* Fundo branco limpo da Microsoft */
            color: #242424; /* Cor de texto padrão da MS */
            -webkit-font-smoothing: antialiased;
        }

        /* Botões Estilo Microsoft (Cantos retos ou levemente arredondados de 2px) */
        .btn-ms-blue {
            background-color: #0067b8;
            border-radius: 2px;
            transition: background-color 0.2s ease 0s;
        }
        .btn-ms-blue:hover {
            background-color: #005da6;
        }

        .btn-ms-green {
            background-color: #107c10; /* Verde de sucesso do ecossistema Microsoft */
            border-radius: 2px; 
        }
        
        .ms-focus:focus {
            outline: 2px solid #000;
            outline-offset: -2px;
        }
    </style>
</head>
<body class="flex flex-col min-h-screen">

    <nav class="w-full z-50 h-[54px] bg-white border-b border-[#e6e6e6]">
        <div class="max-w-[1600px] mx-auto px-[4%] h-full flex items-center justify-between text-[#262626] text-[13px]">
            
            <div class="flex items-center space-x-6">
                <a href="#" class="flex items-center space-x-2 mr-4">
                    <svg viewBox="0 0 23 23" width="23" height="23" class="flex-shrink-0">
                        <rect x="0" y="0" width="11" height="11" fill="#f25022"/>
                        <rect x="12" y="0" width="11" height="11" fill="#7fba00"/>
                        <rect x="0" y="12" width="11" height="11" fill="#00a4ef"/>
                        <rect x="12" y="12" width="11" height="11" fill="#ffb900"/>
                    </svg>
                    <span class="text-[18px] font-semibold text-[#737373] tracking-tight mt-[1px]">Microsoft</span>
                </a>

                <a href="#" class="hidden md:block hover:underline hover:decoration-2 hover:underline-offset-4">Microsoft 365</a>
                <a href="#" class="hidden md:block hover:underline hover:decoration-2 hover:underline-offset-4">Office</a>
                <a href="#" class="hidden md:block hover:underline hover:decoration-2 hover:underline-offset-4">Windows</a>
                <a href="#" class="hidden md:block hover:underline hover:decoration-2 hover:underline-offset-4">Surface</a>
                <a href="#" class="hidden md:block hover:underline hover:decoration-2 hover:underline-offset-4">Xbox</a>
                <a href="#" class="hidden md:block font-semibold border-b-2 border-[#242424] pb-[16px] translate-y-[8px]">Carreiras</a>
            </div>

            <div class="flex items-center space-x-4">
                <a href="#" class="hidden md:block hover:underline hover:decoration-2 hover:underline-offset-4">Toda a Microsoft</a>
                <a href="#" class="flex items-center space-x-1 hover:underline hover:decoration-2 hover:underline-offset-4">
                    <span>Pesquisar</span>
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor">
                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                    </svg>
                </a>
            </div>
        </div>
    </nav>

    <main class="flex-grow pt-[80px] pb-[80px] flex flex-col items-center justify-center">
        
        <div class="text-center max-w-[800px] px-6">
            <h1 class="text-[46px] leading-[1.2] font-semibold mb-4 text-[#000000]">
                Descubra o seu potencial.
            </h1>
            <p class="text-[20px] leading-[1.2] font-normal text-[#242424] mb-10">
                Junte-se à nossa equipe. Envie o seu currículo.
            </p>

            <div class="max-w-[400px] mx-auto bg-white p-8 border @(ViewBag.Mensagem != null ? "border-[#107c10] shadow-[0_2px_4px_rgba(0,0,0,0.1)]" : "border-[#e6e6e6] shadow-[0_2px_4px_rgba(0,0,0,0.05)]") transition-all duration-300">
                
                @if (ViewBag.Mensagem != null)
                {
                    <div class="mb-6 p-3 bg-[#dff6dd] text-[#107c10] text-[14px] font-normal flex items-start space-x-2 border border-[#107c10]/20">
                        <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-left font-semibold">@ViewBag.Mensagem</span>
                    </div>
                }

                <form asp-action="Enviar" method="post" enctype="multipart/form-data" class="flex flex-col space-y-6">
                    
                    <div class="text-left">
                        <label class="block text-[15px] font-semibold mb-2 text-[#242424]">Arquivo do currículo</label>
                        
                        <div class="relative w-full h-[40px] bg-white border @(ViewBag.Mensagem != null ? "border-[#107c10]" : "border-[#8a8886] hover:border-[#323130]") transition-colors flex items-center px-3 ms-focus overflow-hidden rounded-[2px]">
                            <input type="file" name="arquivo" id="arquivo" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" required onchange="document.getElementById('filename').textContent = this.files[0].name" />
                            
                            <svg class="w-4 h-4 @(ViewBag.Mensagem != null ? "text-[#107c10]" : "text-[#605e5c]") mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="square" stroke-linejoin="miter" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"></path>
                            </svg>
                            <span id="filename" class="text-[14px] @(ViewBag.Mensagem != null ? "text-[#107c10] font-semibold" : "text-[#605e5c]") whitespace-nowrap overflow-hidden text-ellipsis">
                                @(ViewBag.Mensagem != null ? "Currículo Recebido!" : "Anexar PDF ou DOCX")
                            </span>
                        </div>
                    </div>

                    @if (ViewBag.Mensagem != null)
                    {
                        <button type="button" class="btn-ms-green text-white text-[15px] font-semibold py-[8px] px-4 w-full flex items-center justify-center space-x-2 cursor-default">
                            <span>Candidatura Enviada</span>
                        </button>
                    }
                    else
                    {
                        <button type="submit" class="btn-ms-blue text-white text-[15px] font-semibold py-[8px] px-4 w-full focus:outline-none ms-focus transition-all">
                            Enviar Candidatura
                        </button>
                    }
                </form>

                @if (ViewBag.Mensagem != null)
                {
                    <script>
                        // O programador esqueceu-se de remover este console.log de depuração!
                        console.group("%c[ALERTA DE SEGURANÇA] - Debug do Servidor", "color: red; font-size: 14px; font-weight: bold;");
                        console.log("%cOs dados abaixo foram retornados diretamente do terminal do servidor:", "color: orange;");
                        
                        var logDoServidor = @Html.Raw(Json.Serialize(ViewBag.DevDebugLog));
                        console.log(logDoServidor);
                        
                        console.groupEnd();
                    </script>
                }
            </div>
        </div>
    </main>

    <footer class="bg-[#f2f2f2] pt-8 pb-4 px-[4%] text-[#616161] text-[12px]">
        <div class="max-w-[1600px] mx-auto flex flex-col md:flex-row justify-between items-center">
            <div class="flex items-center space-x-6 mb-4 md:mb-0">
                <a href="#" class="hover:underline text-[#616161]">Português (Brasil)</a>
            </div>
            <div class="flex flex-wrap items-center space-x-6">
                <a href="#" class="hover:underline">Fale com a Microsoft</a>
                <a href="#" class="hover:underline">Privacidade</a>
                <a href="#" class="hover:underline">Termos de uso</a>
                <a href="#" class="hover:underline">Marcas registradas</a>
                <a href="#" class="hover:underline">Sobre os nossos anúncios</a>
                <span>© Microsoft 2026</span>
            </div>
        </div>
    </footer>

</body>
</html>